{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "dist",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["node"]
  },

  "include": [
    "src/**/*",
    "api/**/*",
    "prisma/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}