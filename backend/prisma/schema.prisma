generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  role       UserRole @default(editor)

  is_approved Boolean @default(false)
  avatar     String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}


model Category {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  description   String?
  image         String?
  product_count Int       @default(0)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  is_featured   Boolean   @default(false)
  products      Product[]

  @@index([slug])
  @@map("categories")
}

model Product {
  id                String         @id @default(uuid())
  name              String
  slug              String         @unique
  description       String?
  short_description String?
  category_id       String?
  origin            String?
  packaging         String[]
  is_featured       Boolean        @default(false)
  is_export_ready   Boolean        @default(true)
  price_range       String?
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  enquiries         Enquiry[]
  images            ProductImage[]
  category          Category?      @relation(fields: [category_id], references: [id])

  @@index([slug])
  @@index([category_id])
  @@index([is_featured])
  @@map("products")
}

model ProductImage {
  id         String   @id @default(uuid())
  product_id String
  url        String
  alt        String?
  is_primary Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_images")
}

model Enquiry {
  id         String        @id @default(uuid())
  type       EnquiryType
  product_id String?
  name       String
  email      String
  phone      String?
  company    String?
  message    String
  status     EnquiryStatus @default(unread)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  product    Product?      @relation(fields: [product_id], references: [id])

  @@index([status])
  @@index([created_at])
  @@map("enquiries")
}

model Testimonial {
  id          String   @id @default(uuid())
  name        String
  company     String?
  country     String?
  content     String
  avatar      String?
  rating      Int      @default(5)
  is_featured Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([is_featured])
  @@map("testimonials")
}

model HomepageContent {
  id          String          @id @default(dbgenerated("gen_random_uuid()"))
  section     HomepageSection @unique
  title       String?
  subtitle    String?
  badge       String? 
  content     String?
  image       String?
  button_text String?
  button_link String?
  sort_order  Int             @default(0)
  is_active   Boolean         @default(true)
  updated_at  DateTime        @default(now()) @updatedAt

  @@map("homepage_content")
}

model HomepageFeature {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model HomepageJourney {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  icon        String
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model HomepageOrigin {
  id          String   @id @default(cuid())
  name        String
  region      String
  description String
  spices      String[]
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model HomepageCertification {
  id         String   @id @default(cuid())
  name       String
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model AboutContent {
  id         String       @id @default(uuid())
  section    AboutSection @unique
  title      String?
  subtitle   String?   
  badge      String? 
  content    String?
  description String? 
  image      String?
  countries  String[] 
  sort_order Int          @default(0)
  updated_at DateTime     @updatedAt

  @@map("about_content")
}

model ProductsContent {
  id         String          @id @default(uuid())
  section    ProductsSection @unique
  title      String?
  subtitle   String?
  badge      String?
  content    String?
  image      String?
  updated_at DateTime        @updatedAt

  @@map("products_content")
}

model ContactInfo {
  id            String   @id @default(uuid())
  badge               String?   
  title               String?  
  description         String?
  company_description String?
  address       String?
  city          String?
  country       String?
  phone         String?
  email         String?
  working_hours String?
  map_embed     String?
  updated_at    DateTime @updatedAt

  @@map("contact_info")
}

enum UserRole {
  super_admin
  admin
  editor
}

enum EnquiryType {
  product
  general
}

enum EnquiryStatus {
  unread
  read
  replied
}

enum HomepageSection {
  hero
  intro
  quality
  why_choose
  cta
  category_intro
}

enum AboutSection {
  hero
  story
  heritage
  sourcing
  mission
  vision
  export
  cta
}

enum ProductsSection {
  hero
}
